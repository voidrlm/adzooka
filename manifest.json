{
    "manifest_version": 3,
    "name": "Adzooka",
    "description": "Rest in peace, ads. You just got hit by a bazooka.",
    "version": "3.0.0",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "activeTab",
        "declarativeNetRequest",
        "declarativeNetRequestWithHostAccess",
        "scripting",
        "storage",
        "tabs"
    ],
    "host_permissions": ["<all_urls>"],
    "content_scripts": [
        {
            "css": ["cosmetic.css"],
            "matches": ["http://*/*", "https://*/*"],
            "run_at": "document_start"
        },
        {
            "js": ["content-blocker.js"],
            "matches": ["http://*/*", "https://*/*"],
            "run_at": "document_start"
        },
        {
            "js": ["youtube-main.js"],
            "matches": ["*://*.youtube.com/*"],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "js": ["youtube-blocker.js"],
            "matches": ["*://*.youtube.com/*"],
            "run_at": "document_start"
        }
    ],
    "declarative_net_request": {
        "rule_resources": [
            { "id": "adzooka-rules", "enabled": true, "path": "rules.json" }
        ]
    }
}
